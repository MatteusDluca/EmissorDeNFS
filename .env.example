# NFS-e Emissor - Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL
DATABASE_URL=postgresql://nfse_user:nfse_pass@postgres:5432/nfse_db?schema=public
POSTGRES_USER=nfse_user
POSTGRES_PASSWORD=nfse_pass
POSTGRES_DB=nfse_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Certificate Security
CERT_SECRET=your-aes-256-key-must-be-32-chars!!

# Prefeitura Mock
PREFEITURA_MOCK_URL=http://prefeitura-mock:4000/nfse

# Webhook
WEBHOOK_URL=http://localhost:8080/webhook
WEBHOOK_TIMEOUT_MS=5000

# API
API_PORT=3000
NODE_ENV=development

# Worker
WORKER_CONCURRENCY=3

# Admin Seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
