{
    "name": "@nfse/worker",
    "version": "1.0.0",
    "description": "NFS-e Emissor Worker - Processamento assíncrono de notas",
    "private": true,
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/bullmq": "^10.0.1",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^10.3.0",
        "@prisma/client": "^5.8.0",
        "axios": "^1.6.5",
        "bullmq": "^5.1.0",
        "joi": "^17.12.0",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.1",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.3.0",
        "@nestjs/testing": "^10.3.0",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.0",
        "jest": "^29.7.0",
        "prisma": "^5.8.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}